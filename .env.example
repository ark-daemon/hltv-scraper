# Base URL of the target data platform
BASE_URL=https://www.hltv.org

# Browser backend: cloakbrowser | camoufox
BROWSER_BACKEND=cloakbrowser

# Optional proxy (leave empty for direct connection)
BROWSER_PROXY=

# Optional: enable GeoIP localization (true | false)
BROWSER_GEOIP=false

# Human-like interaction preset
BROWSER_HUMAN_PRESET=default
